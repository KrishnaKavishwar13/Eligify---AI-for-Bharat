# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=your-account-id

# DynamoDB Tables
DYNAMODB_STUDENTS_TABLE=eligify-students
DYNAMODB_SKILLS_TABLE=eligify-skills
DYNAMODB_INTERNSHIPS_TABLE=eligify-internships
DYNAMODB_PROJECTS_TABLE=eligify-projects
DYNAMODB_VALIDATIONS_TABLE=eligify-validations

# S3 Buckets
S3_RESUME_BUCKET=eligify-resumes

# Cognito
COGNITO_USER_POOL_ID=your-user-pool-id
COGNITO_CLIENT_ID=your-client-id

# JWT
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
JWT_ALGORITHM=HS256

# AI Services
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
OPENAI_API_KEY=your-openai-api-key

# API Configuration
API_BASE_URL=http://localhost:8000
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# Environment
ENVIRONMENT=development
