# Backend API Configuration
# Copy this file to .env.local and configure for your environment

# Backend API URL
# Development: Python FastAPI backend
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Mock API Mode
# Set to 'true' to use mock data (no backend required)
# Set to 'false' to connect to real Python FastAPI backend
NEXT_PUBLIC_USE_MOCK_API=true

# File Upload Configuration
NEXT_PUBLIC_MAX_FILE_SIZE=10485760
NEXT_PUBLIC_ALLOWED_FILE_TYPES=.pdf,.docx,.txt

# JWT Configuration (for backend auth)
NEXT_PUBLIC_JWT_SECRET=your-jwt-secret-here
