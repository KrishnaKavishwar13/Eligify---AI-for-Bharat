# Eligify Backend - Production Environment Variables

# REQUIRED - Security
JWT_SECRET=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING_MIN_32_CHARS
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# REQUIRED - CORS
CORS_ORIGINS=https://your-frontend-domain.vercel.app,https://www.yourdomain.com

# AI Service (Ollama)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Optional - Logging
LOG_LEVEL=INFO

# Optional - AWS (if using DynamoDB/S3)
# AWS_REGION=ap-south-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# DYNAMODB_TABLE_PREFIX=eligify-prod
# S3_BUCKET_NAME=eligify-resumes

# Optional - Database (if migrating from JSON)
# DATABASE_URL=postgresql://user:pass@host:5432/eligify
